# =============================================================
# NeuroForged Lead System — Environment Variables
# Copy this file to .env and fill in values for local dev.
# Never commit .env to source control.
# =============================================================

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/leadsystem
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Mail (SMTP) ---
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
SPRING_MAIL_FROM=your-email@gmail.com
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# --- App Secrets ---
# Generate JWT secret: openssl rand -hex 64
NEUROFORGED_JWT_SECRET=replace-with-64-char-random-string

# Internal token used by chatbots to submit leads via X-Api-Key header
NEUROFORGED_INTERNAL_TOKEN=replace-with-secure-random-token

# Admin account seeded on startup
NEUROFORGED_ADMIN_EMAIL=admin@yourdomain.com
NEUROFORGED_ADMIN_PASSWORD=replace-with-strong-password

# --- Calendly OAuth ---
# Create an OAuth app at https://developer.calendly.com
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
CALENDLY_REDIRECT_URI=http://localhost:8080/api/calendly/oauth/callback
CALENDLY_WEBHOOK_SIGNING_KEY=your-calendly-webhook-signing-key

# --- CORS (local only — prod uses NEUROFORGED_CORS_ALLOWED_ORIGINS) ---
# Handled in application-local.yml as localhost:3000,localhost:5173
# No env var needed for local dev

# =============================================================
# Render (prod-only) env vars — set in Render dashboard, not here:
#   SPRING_PROFILES_ACTIVE=prod
#   NEUROFORGED_CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
#   NEUROFORGED_MAIL_FROM=noreply@yourdomain.com
#   (plus all of the above with prod values)
# =============================================================
